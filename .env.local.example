# Supabase (Section 2.3) — create a new project with a @veltronpartners.com account (Section 18.2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Staff webmail — existing Go54 cPanel mailboxes via IMAP/SMTP (Section 11.2)
# mail.veltronpartners.com's TLS cert is actually issued for the underlying
# shared server hostname, not the domain alias — use the real server
# hostname until Go54 issues a matching cert for mail.veltronpartners.com.
MAIL_SERVER_HOST=wghp7.wghservers.com
MAIL_IMAP_PORT=993
MAIL_SMTP_PORT=465
MAIL_USE_SSL=true

# Slack integration (Section 7.5)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Notion integration (Section 7.6)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# System notification email — password resets, invites, approvals (Section 2.1)
RESEND_API_KEY=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# AES-256 key for encrypting TOTP secrets + mailbox passwords at rest (Section 14/11.11)
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# Verifies requests to /api/cron/daily-backup actually came from Vercel Cron
# (Vercel auto-attaches this as a Bearer token when the env var is set).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Google integrations — optional, per-staff opt-in only (Section 7.1), never required for login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
